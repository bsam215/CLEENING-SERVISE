# Environment Variables Example
# Copy this to .env.local and fill in the values

# API Configuration
VITE_API_URL=https://api.example.com
VITE_API_KEY=your_api_key_here

# Environment
NODE_ENV=production

# Analytics (Optional)
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Other
VITE_APP_URL=https://yourdomain.com
